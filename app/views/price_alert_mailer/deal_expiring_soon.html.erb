<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deal Expiring Soon!</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f9fafb; margin: 0; padding: 20px;">
  <div style="max-width: 600px; margin: 0 auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="background: linear-gradient(135deg, #f97316, #ea580c); padding: 32px 24px; text-align: center;">
      <p style="color: rgba(255,255,255,0.9); font-size: 14px; margin: 0 0 8px;">Heads up!</p>
      <h1 style="color: white; font-size: 24px; font-weight: 700; margin: 0;">Deal Expiring Soon!</h1>
    </div>
    <div style="padding: 24px;">
      <p style="color: #374151; margin: 0 0 20px;">A deal you saved is about to expire. Don't miss out!</p>
      <div style="border: 1px solid #e5e7eb; border-radius: 10px; padding: 16px; margin-bottom: 20px;">
        <p style="font-weight: 700; font-size: 16px; color: #111827; margin: 0 0 6px;"><%= @product.name %></p>
        <p style="color: #f97316; font-size: 22px; font-weight: 800; margin: 0 0 6px;">$<%= @product.price %></p>
        <% if @expires_at %>
          <p style="color: #dc2626; font-size: 13px; margin: 0;">Expires: <%= @expires_at.strftime('%d %b %Y %H:%M') %> AEST</p>
        <% end %>
      </div>
      <div style="text-align: center; margin-bottom: 24px;">
        <a href="<%= @deal_url %>" style="background: #f97316; color: white; font-weight: 700; font-size: 15px; padding: 14px 32px; border-radius: 10px; text-decoration: none; display: inline-block;">Grab this deal now</a>
      </div>
      <p style="color: #9ca3af; font-size: 12px; text-align: center; margin: 0;">
        <a href="<%= @unsubscribe_url %>" style="color: #9ca3af;">Unsubscribe</a> from deal expiry alerts.
      </p>
    </div>
  </div>
  <% if @tracking_pixel_url %>
    <img src="<%= @tracking_pixel_url %>" width="1" height="1" alt="" style="display:none;">
  <% end %>
</body>
</html>
