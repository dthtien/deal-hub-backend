<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; }
    .header { background: #ff3c00; padding: 24px; text-align: center; }
    .header h1 { color: #fff; margin: 0; font-size: 22px; }
    .content { padding: 32px 24px; text-align: center; }
    .product-image { max-width: 200px; border-radius: 8px; }
    .badge { display: inline-block; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: bold; margin: 8px 0; }
    .badge-drop { background: #ff3c00; color: #fff; }
    .badge-discount { background: #22c55e; color: #fff; }
    .price-current { font-size: 36px; font-weight: bold; color: #22c55e; }
    .price-old { text-decoration: line-through; color: #999; font-size: 20px; margin-right: 8px; }
    .price-arrow { color: #666; font-size: 20px; margin: 0 4px; }
    .store { color: #888; font-size: 14px; margin-top: 8px; }
    .cta { display: inline-block; margin-top: 24px; background: #ff3c00; color: #fff; text-decoration: none; border-radius: 8px; padding: 16px 40px; font-size: 18px; font-weight: bold; }
    .footer { background: #f4f4f4; padding: 20px; text-align: center; font-size: 12px; color: #888; }
    .footer a { color: #ff3c00; text-decoration: none; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Price Drop Alert!</h1>
    </div>
    <div class="content">
      <% if @product.image_url.present? %>
        <img src="<%= @product.image_url %>" class="product-image" alt="<%= @product.name %>">
      <% end %>

      <h2 style="margin-bottom: 8px;"><%= @product.name %></h2>

      <% if @product.store.present? %>
        <p class="store"><%= @product.store %></p>
      <% end %>

      <span class="badge badge-drop">Price Dropped!</span>

      <div style="margin: 20px 0;">
        <span class="price-old">$<%= '%.2f' % @old_price.to_f %></span>
        <span class="price-arrow">&rarr;</span>
        <span class="price-current">$<%= '%.2f' % @current_price.to_f %></span>
      </div>

      <% if @discount.to_i > 0 %>
        <span class="badge badge-discount"><%= @discount.to_i %>% off</span>
      <% end %>

      <% if @alert.target_price.present? %>
        <p style="color: #888; font-size: 14px; margin-top: 12px;">
          Your target price: $<%= '%.2f' % @alert.target_price.to_f %>
        </p>
      <% end %>

      <br>
      <a href="<%= @deal_url %>" class="cta">View Deal</a>
    </div>
    <div class="footer">
      <p>You set up this price alert at <a href="<%= @site_url %>">ozvfy.com</a></p>
      <p><a href="<%= @site_url %>">OzVFY</a> &mdash; Best Deals in Australia</p>
    </div>
  </div>
</body>
</html>
