<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; }
    .header { background: #ff3c00; padding: 24px; text-align: center; }
    .header h1 { color: #fff; margin: 0; font-size: 22px; }
    .content { padding: 32px 24px; text-align: center; }
    .product-image { max-width: 200px; border-radius: 8px; }
    .price { font-size: 32px; font-weight: bold; color: #22c55e; }
    .old-price { text-decoration: line-through; color: #999; font-size: 18px; }
    .cta { display: inline-block; margin-top: 24px; background: #ff3c00; color: #fff; text-decoration: none; border-radius: 8px; padding: 14px 32px; font-size: 16px; font-weight: bold; }
    .footer { background: #f4f4f4; padding: 16px; text-align: center; font-size: 12px; color: #888; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>🚨 Price Drop Alert!</h1>
    </div>
    <div class="content">
      <% if @product.image_url.present? %>
        <img src="<%= @product.image_url %>" class="product-image" alt="<%= @product.name %>">
      <% end %>
      <h2><%= @product.name %></h2>
      <p>The price just dropped to your target!</p>
      <div>
        <span class="price">$<%= @product.price %></span>
        <% if @product.old_price.present? %>
          <span class="old-price"> $<%= @product.old_price %></span>
        <% end %>
      </div>
      <p style="color:#888; font-size:14px;">Your target was: $<%= @alert.target_price %></p>
      <a href="<%= @site_url %>/deals/<%= @product.id %>" class="cta">🛍️ Grab This Deal</a>
    </div>
    <div class="footer">
      <p><a href="<%= @site_url %>">OzVFY — Best Deals in Australia</a></p>
    </div>
  </div>
</body>
</html>
