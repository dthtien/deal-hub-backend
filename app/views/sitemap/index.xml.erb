<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://www.ozvfy.com/</loc>
    <changefreq>hourly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://www.ozvfy.com/subscribe</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>https://www.ozvfy.com/sitemap</loc>
    <changefreq>weekly</changefreq>
    <priority>0.4</priority>
  </url>
  <url>
    <loc>https://www.ozvfy.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://www.ozvfy.com/privacy-policy</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>
  <url>
    <loc>https://www.ozvfy.com/deals/new</loc>
    <changefreq>hourly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://www.ozvfy.com/best-drops</loc>
    <changefreq>hourly</changefreq>
    <priority>0.9</priority>
  </url>

  <%# Store pages %>
<% @stores.each do |store| %>
  <url>
    <loc>https://www.ozvfy.com/stores/<%= CGI.escape(store) %></loc>
    <changefreq>daily</changefreq>
    <priority>0.7</priority>
  </url>
<% end %>

  <%# Category pages %>
<% @categories.each do |cat| %>
  <url>
    <loc>https://www.ozvfy.com/categories/<%= CGI.escape(cat) %></loc>
    <changefreq>daily</changefreq>
    <priority>0.6</priority>
  </url>
<% end %>

  <%# Search landing pages %>
<% @searches.each do |q| %>
  <url>
    <loc>https://www.ozvfy.com/deals/search/<%= CGI.escape(q.downcase) %></loc>
    <changefreq>daily</changefreq>
    <priority>0.7</priority>
  </url>
<% end %>

  <%# Deal pages %>
<% @products.each do |product| %>
  <url>
    <loc>https://www.ozvfy.com/deals/<%= product.id %></loc>
    <lastmod><%= product.updated_at.strftime('%Y-%m-%d') %></lastmod>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>
<% end %>
</urlset>
