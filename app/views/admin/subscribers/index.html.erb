<% content_for :title, "Subscribers" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Subscribers <span class="text-gray-400 font-normal text-lg">(<%= number_with_delimiter(@total) %>)</span></h1>
  <div class="flex items-center gap-3">
    <%= link_to "Export CSV", export_admin_subscribers_path(format: :csv),
        class: "bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors" %>
    <button onclick="document.getElementById('import-modal').classList.remove('hidden')"
      class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
      Import CSV
    </button>
  </div>
</div>

<!-- Import Modal -->
<div id="import-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <div class="bg-white rounded-xl shadow-xl p-6 w-96">
    <h2 class="text-lg font-bold text-gray-900 mb-4">Import Subscribers from CSV</h2>
    <p class="text-sm text-gray-500 mb-4">CSV must have an <code class="bg-gray-100 px-1 rounded">email</code> column. Existing subscribers will be skipped.</p>
    <%= form_with url: import_admin_subscribers_path, method: :post, multipart: true, local: true do |f| %>
      <div class="mb-4">
        <%= f.file_field :csv_file, accept: '.csv', class: "block w-full text-sm text-gray-700 border border-gray-200 rounded-lg p-2 focus:outline-none focus:border-orange-400" %>
      </div>
      <div class="flex items-center gap-3">
        <%= f.submit "Import", class: "bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-lg cursor-pointer transition-colors" %>
        <button type="button" onclick="document.getElementById('import-modal').classList.add('hidden')"
          class="text-sm text-gray-500 hover:text-gray-700">Cancel</button>
      </div>
    <% end %>
  </div>
</div>

<!-- Segment Dashboard -->
<% if @segments.present? %>
<div class="bg-white rounded-xl shadow-sm p-6 mb-6">
  <h2 class="text-base font-bold text-gray-900 mb-4">Subscriber Segments</h2>
  <div class="flex flex-col md:flex-row gap-6 items-start">
    <!-- Pie Chart SVG -->
    <div class="flex-shrink-0">
      <%
        seg_colors = { 'new' => '#f97316', 'active' => '#22c55e', 'at_risk' => '#eab308', 'churned' => '#ef4444' }
        total_segs = @segments.sum { |s| s[:count] }.to_f
        cx = 60; cy = 60; r = 50
        start_angle = -Math::PI / 2
        slices = @segments.map do |seg|
          pct = total_segs > 0 ? seg[:count] / total_segs : 0
          angle = pct * 2 * Math::PI
          x1 = cx + r * Math.cos(start_angle)
          y1 = cy + r * Math.sin(start_angle)
          end_angle = start_angle + angle
          x2 = cx + r * Math.cos(end_angle)
          y2 = cy + r * Math.sin(end_angle)
          large = angle > Math::PI ? 1 : 0
          path = "M #{cx} #{cy} L #{x1.round(2)} #{y1.round(2)} A #{r} #{r} 0 #{large} 1 #{x2.round(2)} #{y2.round(2)} Z"
          start_angle = end_angle
          { seg: seg[:segment], path: path, color: seg_colors[seg[:segment]] || '#9ca3af', pct: (pct * 100).round(1) }
        end
      %>
      <svg width="120" height="120" viewBox="0 0 120 120">
        <% slices.each do |sl| %>
          <% if sl[:pct] > 0 %>
            <path d="<%= sl[:path] %>" fill="<%= sl[:color] %>" stroke="white" stroke-width="1" />
          <% end %>
        <% end %>
      </svg>
    </div>
    <!-- Segment stats -->
    <div class="flex-1 grid grid-cols-2 gap-3">
      <% @segments.each do |seg| %>
        <div class="flex items-start gap-3 bg-gray-50 rounded-lg p-3">
          <span class="w-3 h-3 rounded-full mt-1 flex-shrink-0" style="background-color: <%= seg_colors[seg[:segment]] || '#9ca3af' %>"></span>
          <div class="flex-1">
            <p class="text-xs font-semibold text-gray-700 capitalize"><%= seg[:segment].tr('_', ' ') %></p>
            <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(seg[:count]) %></p>
            <p class="text-xs text-gray-400"><%= seg[:percent] %>%</p>
            <button class="mt-1 text-xs text-orange-500 hover:text-orange-600 font-medium" onclick="alert('Send to <%= seg[:segment] %> segment - coming soon')">
              Send to segment
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<!-- Filters -->
<form method="get" class="flex items-center gap-3 mb-6">
  <input type="text" name="q" value="<%= @q %>" placeholder="Search by email…"
    class="border border-gray-200 rounded-lg px-3 py-2 text-sm w-64 focus:outline-none focus:border-orange-400" />
  <select name="status" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-orange-400">
    <option value="">All statuses</option>
    <option value="active" <%= 'selected' if @status == 'active' %>>Active</option>
    <option value="unsubscribed" <%= 'selected' if @status == 'unsubscribed' %>>Unsubscribed</option>
    <option value="pending" <%= 'selected' if @status == 'pending' %>>Pending</option>
  </select>
  <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">Filter</button>
  <a href="/admin/subscribers" class="text-sm text-gray-400 hover:text-gray-600">Reset</a>
</form>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-100">
      <tr>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Email</th>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Status</th>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Joined</th>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Preferences</th>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% @subscribers.each do |sub| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3 text-gray-800 font-medium"><%= sub.email %></td>
          <td class="px-4 py-3">
            <% badge_class = case sub.status
               when 'active'        then 'bg-emerald-100 text-emerald-700'
               when 'unsubscribed'  then 'bg-gray-100 text-gray-500'
               else                      'bg-amber-100 text-amber-700'
               end %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= badge_class %>">
              <%= sub.status.capitalize %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-500"><%= sub.created_at.strftime('%d %b %Y') %></td>
          <td class="px-4 py-3 text-gray-500 text-xs max-w-xs truncate">
            <% if sub.preferences.present? && sub.preferences.any? %>
              <%= sub.preferences.map { |k, v| "#{k}: #{v}" }.join(', ') %>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <% if sub.status != 'unsubscribed' %>
              <%= button_to "Unsubscribe", unsubscribe_admin_subscriber_path(sub), method: :post,
                  class: "text-xs text-red-500 hover:text-red-700 font-medium border border-red-200 hover:border-red-400 px-3 py-1 rounded-lg transition-colors",
                  data: { confirm: "Unsubscribe #{sub.email}?" } %>
            <% else %>
              <span class="text-xs text-gray-300">—</span>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @subscribers.empty? %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">No subscribers found.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if @total_pages > 1 %>
  <div class="flex items-center gap-2 mt-4 justify-center">
    <% (1..@total_pages).each do |p| %>
      <a href="?page=<%= p %>&q=<%= @q %>&status=<%= @status %>"
        class="px-3 py-1.5 rounded-lg text-sm <%= @page == p ? 'bg-orange-500 text-white font-semibold' : 'bg-white border border-gray-200 text-gray-600 hover:border-orange-300' %>">
        <%= p %>
      </a>
    <% end %>
  </div>
<% end %>
