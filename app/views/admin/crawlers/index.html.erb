<h1 class="text-2xl font-bold mb-6">Crawler Health Dashboard</h1>

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Store</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Deal Count</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Crawled</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @crawler_stats.each do |stat| %>
        <tr>
          <td class="px-4 py-3 text-sm font-semibold text-gray-800"><%= stat[:store] %></td>
          <td class="px-4 py-3 text-sm text-gray-700"><%= stat[:deal_count].to_s %> active</td>
          <td class="px-4 py-3 text-sm text-gray-500">
            <%= stat[:last_crawled_at] ? stat[:last_crawled_at].strftime('%d %b %Y %H:%M') : 'Never' %>
          </td>
          <td class="px-4 py-3">
            <% status_classes = { green: 'bg-green-100 text-green-700', orange: 'bg-yellow-100 text-yellow-700', red: 'bg-red-100 text-red-700' } %>
            <% status_labels = { green: '✅ Fresh (<6h)', orange: '⚠️ Stale (<24h)', red: '🔴 Old (>24h)' } %>
            <span class="px-2 py-0.5 rounded text-xs font-semibold <%= status_classes[stat[:status]] %>">
              <%= status_labels[stat[:status]] %>
            </span>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
