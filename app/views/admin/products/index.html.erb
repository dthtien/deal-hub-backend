<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Products</h1>
  <span class="text-sm text-gray-500"><%= @total %> total</span>
</div>

<%# Filters %>
<form method="get" class="flex gap-3 mb-6 flex-wrap">
  <select name="store" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
    <option value="">All Stores</option>
    <% @stores.each do |store| %>
      <option value="<%= store %>" <%= 'selected' if params[:store] == store %>><%= store %></option>
    <% end %>
  </select>
  <select name="expired" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
    <option value="">All</option>
    <option value="false" <%= 'selected' if params[:expired] == 'false' %>>Active</option>
    <option value="true" <%= 'selected' if params[:expired] == 'true' %>>Expired</option>
  </select>
  <button type="submit" class="bg-orange-500 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-orange-600">Filter</button>
  <a href="/admin/products" class="border border-gray-300 text-gray-600 px-4 py-2 rounded-lg text-sm hover:bg-gray-50">Reset</a>
</form>

<%# Bulk Actions %>
<form id="bulk-form" action="<%= bulk_update_admin_products_path %>" method="post" class="mb-4">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <div class="flex items-center gap-3 flex-wrap">
    <select name="action_type" id="bulk-action-type" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
      <option value="">-- Bulk Action --</option>
      <option value="expire">Mark Expired</option>
      <option value="feature">Feature</option>
      <option value="unfeature">Unfeature</option>
    </select>
    <button type="submit" class="bg-gray-700 hover:bg-gray-800 text-white text-sm font-semibold px-4 py-2 rounded-lg">Apply to Selected</button>
    <button type="button" id="bulk-flash-btn" class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-lg">⚡ Mark Flash Deal</button>
    <button type="button" id="bulk-delete-btn" class="bg-rose-700 hover:bg-rose-800 text-white text-sm font-semibold px-4 py-2 rounded-lg">🗑 Delete Selected</button>
    <span id="selected-count" class="text-sm text-gray-500">0 selected</span>
  </div>
</form>

<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-4 py-3"><input type="checkbox" id="select-all" class="rounded border-gray-300" /></th>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Product</th>
        <th class="text-left px-4 py-3 font-semibold text-gray-600">Store</th>
        <th class="text-right px-4 py-3 font-semibold text-gray-600">Price</th>
        <th class="text-right px-4 py-3 font-semibold text-gray-600">Discount</th>
        <th class="text-center px-4 py-3 font-semibold text-gray-600">Expired</th>
        <th class="text-center px-4 py-3 font-semibold text-gray-600">Featured</th>
        <th class="text-center px-4 py-3 font-semibold text-gray-600">Flash</th>
        <th class="text-center px-4 py-3 font-semibold text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 text-center">
            <input type="checkbox" form="bulk-form" name="ids[]" value="<%= product.id %>" class="product-checkbox rounded border-gray-300" />
          </td>
          <td class="px-4 py-3">
            <a href="/deals/<%= product.id %>" target="_blank" class="text-orange-600 hover:underline font-medium"><%= truncate(product.name, length: 55) %></a>
            <% if @duplicate_product_ids.include?(product.id) %>
              <span class="ml-1 inline-block text-xs px-1.5 py-0.5 bg-amber-100 text-amber-700 rounded font-semibold" title="Another product with same name+store exists">
                ⚠️ Possible duplicate
              </span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= product.store %></td>
          <td class="px-4 py-3 text-right font-semibold">$<%= product.price %></td>
          <td class="px-4 py-3 text-right text-gray-500"><%= product.discount.present? ? "#{product.discount}%" : '—' %></td>
          <td class="px-4 py-3 text-center">
            <%= button_to admin_product_path(product, field: 'expired', **request.query_parameters.except('_method')), method: :patch, class: "px-2 py-1 rounded text-xs font-semibold #{product.expired? ? 'bg-red-100 text-red-700 hover:bg-red-200' : 'bg-green-100 text-green-700 hover:bg-green-200'}" do %>
              <%= product.expired? ? 'Yes' : 'No' %>
            <% end %>
          </td>
          <td class="px-4 py-3 text-center">
            <%= button_to admin_product_path(product, field: 'featured', **request.query_parameters.except('_method')), method: :patch, class: "px-2 py-1 rounded text-xs font-semibold #{product.featured? ? 'bg-orange-100 text-orange-700 hover:bg-orange-200' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}" do %>
              <%= product.featured? ? 'Yes' : 'No' %>
            <% end %>
          </td>
          <td class="px-4 py-3 text-center">
            <% if product.flash_deal? && product.flash_expires_at&.future? %>
              <span class="px-2 py-1 rounded text-xs font-semibold bg-red-100 text-red-700">⚡ Active</span>
            <% else %>
              <%= button_to mark_flash_admin_product_path(product), method: :post, class: "px-2 py-1 rounded text-xs font-semibold bg-gray-100 text-gray-500 hover:bg-red-100 hover:text-red-700" do %>
                Set Flash
              <% end %>
            <% end %>
          </td>
          <td class="px-4 py-3 text-center flex items-center gap-1 justify-center">
            <a href="<%= admin_product_path(product) %>" class="text-blue-500 text-xs hover:underline">Edit</a>
            <% if @duplicate_product_ids.include?(product.id) %>
              <button
                class="text-amber-600 text-xs hover:underline merge-btn"
                data-product-id="<%= product.id %>"
                data-product-name="<%= product.name.gsub('"', '&quot;') %>"
                data-store="<%= product.store %>"
              >Merge</button>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# Pagination %>
<% if @total_pages > 1 %>
  <div class="flex gap-2 mt-4 justify-center">
    <% (1..@total_pages).each do |p| %>
      <a href="?<%= request.query_parameters.merge(page: p).to_query %>" class="px-3 py-1.5 rounded-lg text-sm <%= @page == p ? 'bg-orange-500 text-white font-bold' : 'border border-gray-300 text-gray-600 hover:bg-gray-50' %>"><%= p %></a>
    <% end %>
  </div>
<% end %>

<script>
  const selectAll = document.getElementById('select-all');
  const checkboxes = document.querySelectorAll('.product-checkbox');
  const countEl = document.getElementById('selected-count');
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '<%= form_authenticity_token %>';

  function getSelectedIds() {
    return Array.from(document.querySelectorAll('.product-checkbox:checked')).map(cb => cb.value);
  }

  function updateCount() {
    const n = document.querySelectorAll('.product-checkbox:checked').length;
    countEl.textContent = n + ' selected';
  }

  selectAll.addEventListener('change', () => {
    checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
    updateCount();
  });
  checkboxes.forEach(cb => cb.addEventListener('change', updateCount));

  document.getElementById('bulk-flash-btn').addEventListener('click', async () => {
    const ids = getSelectedIds();
    if (!ids.length) { alert('Select at least one product.'); return; }
    if (!confirm(`Mark ${ids.length} product(s) as flash deals?`)) return;
    const res = await fetch('<%= bulk_action_admin_products_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ action: 'mark_flash', product_ids: ids })
    });
    const data = await res.json();
    alert(data.message);
    window.location.reload();
  });

  document.getElementById('bulk-delete-btn').addEventListener('click', async () => {
    const ids = getSelectedIds();
    if (!ids.length) { alert('Select at least one product.'); return; }
    if (!confirm(`Delete ${ids.length} product(s)? This cannot be undone.`)) return;
    const res = await fetch('<%= bulk_action_admin_products_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ action: 'delete', product_ids: ids })
    });
    const data = await res.json();
    alert(data.message);
    window.location.reload();
  });

  // Merge duplicate handler
  document.querySelectorAll('.merge-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const productId = btn.getAttribute('data-product-id');
      const productName = btn.getAttribute('data-product-name');
      const store = btn.getAttribute('data-store');
      const primaryId = prompt(
        `Merge product #${productId} ("${productName}", ${store}) into which product ID?\n\nEnter the PRIMARY product ID to keep:`
      );
      if (!primaryId || isNaN(Number(primaryId))) return;
      if (!confirm(`Merge #${productId} into #${primaryId}? This will delete #${productId}.`)) return;
      const res = await fetch('<%= merge_admin_products_path %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
        body: JSON.stringify({ primary_id: Number(primaryId), duplicate_id: Number(productId) })
      });
      const data = await res.json();
      alert(data.message || data.error);
      if (data.message) window.location.reload();
    });
  });
</script>
