<% content_for :title, "Dashboard" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
  <div class="flex items-center gap-3">
    <!-- Crawl status indicator -->
    <div id="crawl-status" class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full <%= @crawl_running ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-100 text-gray-500' %>">
      <span class="inline-block w-2 h-2 rounded-full <%= @crawl_running ? 'bg-emerald-500 animate-pulse' : 'bg-gray-400' %>"></span>
      <%= @crawl_running ? 'Crawl running' : 'No active crawl' %>
    </div>
    <!-- Auto-refresh controls -->
    <span id="last-updated" class="text-xs text-gray-400">Last updated just now</span>
    <button
      id="pause-refresh-btn"
      class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-gray-200 text-gray-500 hover:border-gray-300 hover:text-gray-700 transition-colors"
    >
      Pause auto-refresh
    </button>
  </div>
</div>

<!-- Stats grid -->
<div id="stats-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <% [
    ['Products', @stats[:products], 'bg-blue-500'],
    ['Active Deals', @stats[:active], 'bg-emerald-500'],
    ['Stores', @stats[:stores], 'bg-violet-500'],
    ['Subscribers', @stats[:subscribers], 'bg-orange-500'],
    ['Coupons', @stats[:coupons], 'bg-pink-500'],
    ['Pending Submissions', @stats[:submissions], 'bg-amber-500'],
    ['Votes', @stats[:votes], 'bg-yellow-500'],
    ['Clicks', @stats[:clicks], 'bg-red-500'],
  ].each do |label, value, color| %>
    <div class="bg-white rounded-xl shadow-sm p-5" data-stat="<%= label.downcase.gsub(/\s+/, '_') %>">
      <div class="stat-value text-2xl font-bold text-gray-900"><%= number_with_delimiter(value) %></div>
      <div class="text-sm text-gray-500 mt-1"><%= label %></div>
      <div class="h-1 rounded-full <%= color %> mt-3 opacity-60"></div>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Top stores -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Top Stores by Deal Count</h2>
    <div id="top-stores" class="space-y-2">
      <% @top_stores.each do |store, count| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-700"><%= store %></span>
          <span class="text-sm font-semibold text-gray-900"><%= number_with_delimiter(count) %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent deals -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Recently Added Deals</h2>
    <div id="recent-products" class="space-y-2">
      <% @recent_products.each do |p| %>
        <div class="flex items-center justify-between gap-2">
          <span class="text-sm text-gray-700 truncate flex-1"><%= p.name.to_s.truncate(50) %></span>
          <span class="text-xs text-gray-400 flex-shrink-0"><%= p.store %></span>
          <span class="text-xs font-semibold text-orange-500 flex-shrink-0">$<%= p.price %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Daily product stats bar chart -->
<div class="bg-white rounded-xl shadow-sm p-6 mt-6">
  <h2 class="font-semibold text-gray-800 mb-4">New Products — Last 7 Days</h2>
  <div class="flex items-end gap-2 h-24">
    <% max_count = (@daily_stats.map(&:last).max || 1).to_f %>
    <% @daily_stats.each do |date_label, count| %>
      <div class="flex flex-col items-center flex-1">
        <span class="text-xs text-gray-600 mb-1"><%= count %></span>
        <div class="w-full bg-orange-400 rounded-t" style="height: <%= [(count.to_f / max_count * 80).round, 2].max %>px"></div>
        <span class="text-xs text-gray-400 mt-1 truncate w-full text-center"><%= date_label %></span>
      </div>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
  <!-- Top clicked deals -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Top Clicked Deals</h2>
    <table class="w-full text-sm">
      <thead><tr class="text-left text-xs text-gray-400 border-b"><th class="pb-2">Deal</th><th class="pb-2 text-right">Clicks</th></tr></thead>
      <tbody>
        <% @top_deals.each do |p| %>
          <tr class="border-b border-gray-50">
            <td class="py-2 truncate max-w-xs text-gray-700"><%= p.name.to_s.truncate(45) %></td>
            <td class="py-2 text-right font-semibold text-orange-500"><%= p.click_count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Recent votes -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Recent Votes</h2>
    <div class="space-y-2">
      <% @recent_votes.each do |vote| %>
        <div class="flex items-center justify-between gap-2 text-sm">
          <span class="text-gray-700 truncate flex-1"><%= vote.product&.name.to_s.truncate(40) %></span>
          <span class="flex-shrink-0 font-bold <%= vote.value == 1 ? 'text-emerald-500' : 'text-rose-500' %>"><%= vote.value == 1 ? '👍 Up' : '👎 Down' %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Export links -->
<div class="bg-white rounded-xl shadow-sm p-6 mt-6">
  <h2 class="font-semibold text-gray-800 mb-4">Export Data</h2>
  <div class="flex flex-wrap gap-3">
    <%= link_to '📦 Export Products CSV', admin_export_products_path, class: 'inline-flex items-center gap-2 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors' %>
    <%= link_to '📧 Export Subscribers CSV', admin_export_subscribers_path, class: 'inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors' %>
    <%= link_to '🏷️ Export Coupons CSV', admin_export_coupons_path, class: 'inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors' %>
  </div>
</div>

<script>
(function() {
  var paused = false;
  var intervalId = null;
  var lastUpdatedAt = Date.now();

  var pauseBtn = document.getElementById('pause-refresh-btn');
  var lastUpdatedEl = document.getElementById('last-updated');
  var crawlStatusEl = document.getElementById('crawl-status');

  // Counter: "Last updated X seconds ago"
  function updateCounter() {
    var secs = Math.floor((Date.now() - lastUpdatedAt) / 1000);
    if (secs < 5) {
      lastUpdatedEl.textContent = 'Last updated just now';
    } else if (secs < 60) {
      lastUpdatedEl.textContent = 'Last updated ' + secs + 's ago';
    } else {
      var mins = Math.floor(secs / 60);
      lastUpdatedEl.textContent = 'Last updated ' + mins + 'm ago';
    }
  }
  setInterval(updateCounter, 5000);

  function fetchStats() {
    if (paused) return;
    fetch('<%= admin_dashboard_stats_path %>', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
      .then(function(data) {
        lastUpdatedAt = Date.now();
        updateCounter();

        // Update stats
        var statMap = {
          'products': data.stats.products,
          'active_deals': data.stats.active,
          'stores': data.stats.stores,
          'subscribers': data.stats.subscribers,
          'coupons': data.stats.coupons,
          'pending_submissions': data.stats.submissions,
          'votes': data.stats.votes,
          'clicks': data.stats.clicks
        };
        document.querySelectorAll('[data-stat]').forEach(function(el) {
          var key = el.getAttribute('data-stat');
          if (statMap[key] !== undefined) {
            el.querySelector('.stat-value').textContent = statMap[key].toLocaleString();
          }
        });

        // Update crawl indicator
        if (data.crawl_running) {
          crawlStatusEl.className = 'flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full bg-emerald-100 text-emerald-700';
          crawlStatusEl.innerHTML = '<span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> Crawl running';
        } else {
          crawlStatusEl.className = 'flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full bg-gray-100 text-gray-500';
          crawlStatusEl.innerHTML = '<span class="inline-block w-2 h-2 rounded-full bg-gray-400"></span> No active crawl';
        }

        // Update recent products
        if (data.recent_products && data.recent_products.length > 0) {
          var html = data.recent_products.map(function(p) {
            return '<div class="flex items-center justify-between gap-2">' +
              '<span class="text-sm text-gray-700 truncate flex-1">' + p.name + '</span>' +
              '<span class="text-xs text-gray-400 flex-shrink-0">' + p.store + '</span>' +
              '<span class="text-xs font-semibold text-orange-500 flex-shrink-0">$' + p.price + '</span>' +
              '</div>';
          }).join('');
          document.getElementById('recent-products').innerHTML = html;
        }
      })
      .catch(function() { /* silently fail */ });
  }

  function startRefresh() {
    if (intervalId) clearInterval(intervalId);
    intervalId = setInterval(fetchStats, 30000);
  }

  pauseBtn.addEventListener('click', function() {
    paused = !paused;
    if (paused) {
      pauseBtn.textContent = 'Resume auto-refresh';
      pauseBtn.classList.add('bg-amber-50', 'border-amber-300', 'text-amber-600');
    } else {
      pauseBtn.textContent = 'Pause auto-refresh';
      pauseBtn.classList.remove('bg-amber-50', 'border-amber-300', 'text-amber-600');
      fetchStats();
    }
  });

  startRefresh();
})();
</script>
