<% content_for :title, "Dashboard" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

<!-- Stats grid -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <% [
    ['Products', @stats[:products], 'bg-blue-500'],
    ['Active Deals', @stats[:active], 'bg-emerald-500'],
    ['Stores', @stats[:stores], 'bg-violet-500'],
    ['Subscribers', @stats[:subscribers], 'bg-orange-500'],
    ['Coupons', @stats[:coupons], 'bg-pink-500'],
    ['Votes', @stats[:votes], 'bg-yellow-500'],
    ['Clicks', @stats[:clicks], 'bg-red-500'],
  ].each do |label, value, color| %>
    <div class="bg-white rounded-xl shadow-sm p-5">
      <div class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(value) %></div>
      <div class="text-sm text-gray-500 mt-1"><%= label %></div>
      <div class="h-1 rounded-full <%= color %> mt-3 opacity-60"></div>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Top stores -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Top Stores by Deal Count</h2>
    <div class="space-y-2">
      <% @top_stores.each do |store, count| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-700"><%= store %></span>
          <span class="text-sm font-semibold text-gray-900"><%= number_with_delimiter(count) %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent deals -->
  <div class="bg-white rounded-xl shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Recently Added Deals</h2>
    <div class="space-y-2">
      <% @recent_products.each do |p| %>
        <div class="flex items-center justify-between gap-2">
          <span class="text-sm text-gray-700 truncate flex-1"><%= p.name.to_s.truncate(50) %></span>
          <span class="text-xs text-gray-400 flex-shrink-0"><%= p.store %></span>
          <span class="text-xs font-semibold text-orange-500 flex-shrink-0">$<%= p.price %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>
