<h1 class="text-2xl font-bold mb-4">Coupon Submissions <span class="text-sm font-normal text-gray-500">(<%= @pending_count %> pending)</span></h1>

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Store</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Code</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Discount</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @submissions.each do |s| %>
        <tr>
          <td class="px-4 py-3 text-sm"><%= s.store %></td>
          <td class="px-4 py-3 text-sm font-mono font-bold"><%= s.code %></td>
          <td class="px-4 py-3 text-sm text-gray-600"><%= s.description %></td>
          <td class="px-4 py-3 text-sm"><%= s.discount_value %> <%= s.discount_type %></td>
          <td class="px-4 py-3 text-sm text-gray-500"><%= s.submitted_by_email %></td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 rounded text-xs font-semibold <%= s.status == 'pending' ? 'bg-yellow-100 text-yellow-700' : s.status == 'approved' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
              <%= s.status %>
            </span>
          </td>
          <td class="px-4 py-3 text-sm space-x-2">
            <% if s.status == 'pending' %>
              <%= button_to 'Approve', approve_admin_coupon_submission_path(s), method: :post, class: 'bg-green-500 hover:bg-green-600 text-white px-3 py-1 rounded text-xs font-semibold' %>
              <%= button_to 'Reject', reject_admin_coupon_submission_path(s), method: :post, class: 'bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-xs font-semibold' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
