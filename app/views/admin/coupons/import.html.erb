<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Import Coupons via CSV</h1>
  <%= link_to '← Back to Coupons', admin_coupons_path, class: 'text-sm text-gray-500 hover:text-gray-700' %>
</div>

<% if flash[:notice] %>
  <div class="bg-green-50 text-green-800 px-4 py-3 rounded-lg mb-4"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="bg-red-50 text-red-800 px-4 py-3 rounded-lg mb-4"><%= flash[:alert] %></div>
<% end %>

<div class="bg-white rounded-2xl shadow-sm p-6 max-w-lg">
  <p class="text-sm text-gray-600 mb-4">Upload a CSV file with headers: <code class="bg-gray-100 px-1 rounded text-xs">store,code,description,discount_value,discount_type,expires_at,verified</code></p>
  <%= form_tag import_admin_coupons_path, multipart: true do %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">CSV File</label>
      <input type="file" name="file" accept=".csv" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100" required />
    </div>
    <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-5 py-2 rounded-lg text-sm">Import CSV</button>
  <% end %>
</div>
