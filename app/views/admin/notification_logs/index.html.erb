<h1 class="text-2xl font-bold mb-6">Notification Logs</h1>

<div class="mb-4 flex gap-2">
  <%= link_to 'All', admin_notification_logs_path, class: "px-3 py-1 rounded text-sm #{params[:status].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100'}" %>
  <%= link_to 'Sent', admin_notification_logs_path(status: 'sent'), class: "px-3 py-1 rounded text-sm #{params[:status] == 'sent' ? 'bg-green-600 text-white' : 'bg-gray-100'}" %>
  <%= link_to 'Failed', admin_notification_logs_path(status: 'failed'), class: "px-3 py-1 rounded text-sm #{params[:status] == 'failed' ? 'bg-red-600 text-white' : 'bg-gray-100'}" %>
</div>

<div class="bg-white rounded-xl shadow overflow-hidden">
  <table class="min-w-full text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Recipient</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sent At</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @logs.empty? %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">No notification logs yet</td></tr>
      <% else %>
        <% @logs.each do |log| %>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-gray-600"><%= log.notification_type %></td>
            <td class="px-4 py-3 text-gray-800"><%= log.recipient %></td>
            <td class="px-4 py-3 text-gray-600 max-w-xs truncate"><%= log.subject %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= log.status == 'sent' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= log.status %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= log.created_at.strftime('%d %b %Y %H:%M') %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>

<% if @meta[:total_pages] > 1 %>
  <div class="mt-4 flex gap-2 justify-center">
    <% (1..@meta[:total_pages]).each do |p| %>
      <%= link_to p, admin_notification_logs_path(page: p, status: params[:status]), class: "px-3 py-1 rounded text-sm #{p == @meta[:page] ? 'bg-blue-600 text-white' : 'bg-gray-100'}" %>
    <% end %>
  </div>
<% end %>
