<h1 class="text-2xl font-bold mb-6">Notification Logs</h1>

<%# Open Rate by Type %>
<div class="mb-8">
  <h2 class="text-lg font-semibold mb-3 text-gray-800">Open Rate by Email Type</h2>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-6">
    <% @open_rate_by_type.each do |stat| %>
      <div class="bg-white rounded-xl shadow p-4 border border-gray-100">
        <p class="text-xs font-mono text-gray-500 truncate mb-1"><%= stat[:type] %></p>
        <p class="text-2xl font-bold text-orange-500"><%= stat[:rate] %>%</p>
        <p class="text-xs text-gray-400"><%= stat[:opened] %> / <%= stat[:sent] %> opened</p>
      </div>
    <% end %>
    <% if @open_rate_by_type.empty? %>
      <p class="text-gray-400 col-span-4">No data yet</p>
    <% end %>
  </div>

  <%# Bar chart - open rates by day (last 7 days) %>
  <h2 class="text-lg font-semibold mb-3 text-gray-800">Open Rate by Day (Last 7 Days)</h2>
  <div class="bg-white rounded-xl shadow p-4 border border-gray-100 mb-6">
    <div class="flex items-end gap-3 h-32">
      <% max_rate = [@open_rate_by_day.map { |d| d[:rate] }.max.to_f, 1.0].max %>
      <% @open_rate_by_day.each do |day| %>
        <div class="flex flex-col items-center flex-1 gap-1">
          <span class="text-xs text-gray-500"><%= day[:rate] %>%</span>
          <div
            class="w-full rounded-t bg-orange-400"
            style="height: <%= [(day[:rate] / max_rate * 80).round, 2].max %>px; min-height: 2px;"
            title="<%= day[:date] %>: <%= day[:opened] %>/<%= day[:sent] %> opened (<%= day[:rate] %>%)"
          ></div>
          <span class="text-xs text-gray-400 truncate w-full text-center"><%= day[:date] %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="mb-4 flex gap-2">
  <%= link_to 'All', admin_notification_logs_path, class: "px-3 py-1 rounded text-sm #{params[:status].blank? && params[:type].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100'}" %>
  <%= link_to 'Sent', admin_notification_logs_path(status: 'sent'), class: "px-3 py-1 rounded text-sm #{params[:status] == 'sent' ? 'bg-green-600 text-white' : 'bg-gray-100'}" %>
  <%= link_to 'Failed', admin_notification_logs_path(status: 'failed'), class: "px-3 py-1 rounded text-sm #{params[:status] == 'failed' ? 'bg-red-600 text-white' : 'bg-gray-100'}" %>
</div>

<div class="bg-white rounded-xl shadow overflow-hidden">
  <table class="min-w-full text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Recipient</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Opened</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sent At</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @logs.empty? %>
        <tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">No notification logs yet</td></tr>
      <% else %>
        <% @logs.each do |log| %>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-gray-600"><%= log.notification_type %></td>
            <td class="px-4 py-3 text-gray-800"><%= log.recipient %></td>
            <td class="px-4 py-3 text-gray-600 max-w-xs truncate"><%= log.subject %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= log.status == 'sent' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= log.status %>
              </span>
            </td>
            <td class="px-4 py-3">
              <% if log.opened_at %>
                <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700" title="<%= log.opened_at.strftime('%d %b %Y %H:%M') %>">
                  Opened
                </span>
              <% else %>
                <span class="text-xs text-gray-300">-</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= log.created_at.strftime('%d %b %Y %H:%M') %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>

<% if @meta[:total_pages] > 1 %>
  <div class="mt-4 flex gap-2 justify-center">
    <% (1..@meta[:total_pages]).each do |p| %>
      <%= link_to p, admin_notification_logs_path(page: p, status: params[:status]), class: "px-3 py-1 rounded text-sm #{p == @meta[:page] ? 'bg-blue-600 text-white' : 'bg-gray-100'}" %>
    <% end %>
  </div>
<% end %>
